testdb.php
test_*.php
*_test.php
debug_*.php
api/test/debug.php

# ====================
# IDE / Editor Files
# ====================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ====================
# OS Files
# ====================
Thumbs.db
desktop.ini

# ====================
# Logs & Debugging
# ====================
*.log
error_log
error_log.txt
debug.log
debug.php
test-connection.php

# ====================
# Backup Files
# ====================
*.bak

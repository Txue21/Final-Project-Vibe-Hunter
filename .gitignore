# ====================
# Node.js / NPM (Phase 2 Client)
# ====================
node_modules/
dist/
*.local

# ====================
# Postman / API Testing
# ====================
# Ignore Postman CLI workspace (personal identifiers)
.postman/

# Ignore collections (API documentation & tests)
postman/

# Ignore environment files if they contain secrets
*.postman_environment.json
*.postman_collection.json

# Ignore Postman run/test results
postman-results/
newman/

# ====================
# Notes
# ====================
# Keep these files for instructor review:
# - All api/*.php files (production code)
# - db.php (with placeholder credentials)
# - config.php (TEST_MODE configuration)
# - schema.sql (database schema)
# - setup.php (deployment initialization)
# - index.html (API documentation)
# - README.md (project overview)
# - HOSTINGER_SETUP.md (deployment guide)
# - .htaccess (URL routing)
